      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(bundle exec:*)",
      "Bash(rails test:*)",
      "Bash(rspec:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git -C:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(comm:*)",
      "Bash(sort:*)",
      "Bash(test:*)",
      "Bash(cd:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(docker images:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(cursor agent:*)",
      "Bash(uv run --with pytest pytest:*)",
      "Bash(glab mr view:*)",
      "Bash(glab mr list:*)",
      "Bash(glab mr diff:*)",
      "Bash(glab mr approvers:*)",
      "Bash(glab issue view:*)",
      "Bash(glab issue list:*)",
      "Bash(glab ci view:*)",
      "Bash(glab ci list:*)",
      "Bash(glab ci status:*)",
      "Bash(glab ci get:*)",
      "Bash(glab ci lint:*)",
      "Bash(glab ci trace:*)",
      "Bash(glab repo view:*)",
      "Bash(glab repo list:*)",
      "Bash(glab repo search:*)",
      "Bash(glab release list:*)",
      "Bash(glab release view:*)",
      "Bash(glab variable list:*)",
      "Bash(glab variable get:*)",
      "Bash(glab variable export:*)",
      "Bash(glab config get:*)",
      "Bash(glab auth status:*)",
      "Bash(gog auth list:*)",
      "Bash(gog config list:*)",
      "Bash(gog gmail search:*)",
      "Bash(gog gmail messages search:*)",
      "Bash(gog gmail thread get:*)",
      "Bash(gog gmail labels list:*)",
      "Bash(gog gmail filters list:*)",
      "Bash(gog calendar events:*)",
      "Bash(gog drive ls:*)",
      "Bash(gog drive search:*)",
      "Bash(gog ls:*)",
      "Bash(gog search:*)",
      "Bash(gog contacts search:*)",
      "Bash(gog contacts list:*)",
      "Bash(gog tasks list:*)",
      "Bash(gog open:*)",
      "Bash(gog version:*)",
      "Bash(wt list:*)",
      "Bash(wt config show:*)",
      "Bash(wt --version:*)",
      "Task(Explore)",
      "Task(Plan)",
      "Skill",
      "mcp__deepwiki-http__*",
      "mcp__serena__*",
      "Read(~/.claude/skills/**/*)",
      "Read(~/.dotfiles/.claude-global/skills/**/*)",
      "Read(.claude/skills/**/*)",
      "Bash(~/.dotfiles/.claude-global/skills/scripts/changed-files.sh:*)",
      "Bash(~/.dotfiles/.claude-global/skills/scripts/quality-gate.py:*)",
      "Bash(~/.dotfiles/.claude-global/skills/scripts/review-skills.py:*)",
      "Bash(~/.dotfiles/.claude-global/skills/claude-config/scripts/scan-config.py:*)",
      "Bash(~/.dotfiles/.claude-global/skills/claude-config/scripts/scan-skills.py:*)",
      "Bash(~/.dotfiles/.claude-global/skills/claude-config/scripts/scan-hooks.py:*)",
      "Bash(~/.dotfiles/.claude-global/skills/claude-config/scripts/scan-claude-md.py:*)",
      "Bash(~/.dotfiles/.claude-global/skills/todoist/scripts/todoist.py:*)",
      "Bash(~/.dotfiles/.claude-global/hooks/todoist-url-inject.sh:*)",
      "Bash(~/.dotfiles/.claude-global/skills/scripts/open-in-zed.sh:*)",
      "Bash(~/.dotfiles/.claude-global/hooks/stop-open-zed.sh:*)",
      "Bash(shellcheck:*)",
      "Bash(uvx ruff:*)",
      "Bash(/Applications/draw.io.app/Contents/MacOS/draw.io:*)",
      "Write(**/.claude/dialogues/**)",
      "Write(**/.claude/discovery/**)",
      "Write(**/.claude/plans/**)",
      "Write(**/.claude/research/**)",
      "Write(**/.claude/implement/**)",
      "Write(**/.claude/tmp/**)",
      "Edit(**/.claude/dialogues/**)",
      "Edit(**/.claude/discovery/**)",
      "Edit(**/.claude/plans/**)",
      "Edit(**/.claude/research/**)",
      "Edit(**/.claude/implement/**)",
      "Edit(**/.claude/tmp/**)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "NotebookEdit",
      "NotebookRead",
      "Bash(zsh:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.crt)",
      "Read(**/credentials*)",
      "Read(**/.ssh/*)",
      "Read(**/*.secret)",
      "Read(**/*secret*)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/secrets/**)",
      "Read(**/private/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/*.crt)",
      "Write(**/credentials)",
      "Write(**/.netrc)",
      "Write(**/secrets/**)",
      "Write(**/private/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/*.crt)",
      "Edit(**/credentials)",
      "Edit(**/.netrc)",
      "Edit(**/secrets/**)",
      "Edit(**/private/**)",
      "Bash(wget:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean --force:*)",
      "Bash(git checkout --:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(bash:*)",
      "Bash(sh:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(rm:*)",
      "Bash(rmtrash:*)",
      "Bash(brew install:*)",
      "Bash(npm publish:*)",
      "Bash(kubectl:*)"
    ],
    "defaultMode": "default",
    "allowedPaths": [
      "**/.claude/tmp/**",
      "**/.claude/review/**",
      "**/.claude/discovery/**",
      "**/.claude/plan/**",
      "**/.claude/research/**",
      "**/.claude/dialogue/**"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/guard-multiline.sh"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/guard-git.sh",
            "if": "Bash(git *)"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/guard-shell.sh",
            "if": "Bash(bash *)"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/guard-shell.sh",
            "if": "Bash(sh *)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/pretooluse-guard-write.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/skill-activation.sh"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/todoist-url-inject.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/session-cleanup.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/posttooluse-open-zed.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/posttooluse-ruff-check.sh",
            "if": "Write(*.py)",
            "timeout": 30,
            "statusMessage": "Python構文チェック中..."
          },
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/posttooluse-ruff-check.sh",
            "if": "Edit(*.py)",
            "timeout": 30,
            "statusMessage": "Python構文チェック中..."
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/stop-open-zed.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/.claude-global/hooks/stop-open-zed.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/.claude-global/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "example-skills@anthropic-agent-skills": false,
    "code-simplifier@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "language": "日本語でMBTIでINTJの人がわかりやすい話し方",
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "plansDirectory": ".claude/plans"
}
